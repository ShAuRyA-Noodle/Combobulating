# Xcode user state — generated per-developer, never check in.
xcuserdata/
*.xcworkspace/xcuserdata/
*.xcodeproj/xcuserdata/
*.xcodeproj/project.xcworkspace/xcuserdata/

# Swift Package Manager local state
.swiftpm/
.build/
Packages/
Package.resolved

# Xcode build products
DerivedData/
build/

# Generated by xcodegen — regenerate with `xcodegen generate`. Keeping this
# uncommented means the project is generated locally; comment out if the
# team decides to commit `Aura.xcodeproj`.
# Aura.xcodeproj/

# Google Sign-In secrets — never commit. Each developer drops their own.
GoogleService-Info.plist

# macOS clutter
.DS_Store
